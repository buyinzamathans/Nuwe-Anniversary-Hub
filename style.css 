/* BASE STYLES */
body {
    margin: 0;
    font-family: 'Georgia', serif; /* Classic, romantic feel */
    background-color: #faf9f6; /* Warm off-white */
    color: #2c2c2c;
    line-height: 1.6;
}

h1, h2, h3 {
    font-weight: normal;
    text-align: center;
    margin-top: 0;
}

.section-divider {
    width: 50%;
    border: 0;
    border-top: 1px solid #dcdcdc;
    margin: 40px auto;
}

/* HERO SECTION */
.hero-section {
    text-align: center;
    background-color: #fff;
    padding-bottom: 30px;
}

.hero-image-container {
    width: 100%;
    max-height: 65vh; /* Prevents the image from taking up the entire screen on desktop */
    overflow: hidden;
}

.hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%; /* Keeps faces centered if the image is cropped */
}

.hero-text {
    padding: 30px 20px 0;
}

.hero-text h1 {
    font-size: 2.5rem;
    margin-bottom: 10px;
    color: #1a1a1a;
}

/* TIMELINE SECTION (THE SCRAPBOOK) */
.timeline-section {
    max-width: 800px;
    margin: 0 auto;
    padding: 20px;
    text-align: center;
}

.subtitle {
    color: #666;
    font-style: italic;
    margin-bottom: 30px;
}

.timeline-grid {
    display: flex;
    flex-direction: column;
    gap: 30px;
}

.memory-card {
    background: #fff;
    padding: 15px;
    border-radius: 8px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.05);
}

/* Visual cue for the placeholders */
.memory-card.placeholder .image-box {
    background-color: #f0f0f0;
    border: 2px dashed #ccc;
    height: 250px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    margin-bottom: 15px;
}

.placeholder .image-box p {
    color: #888;
    font-family: 'Arial', sans-serif;
    font-size: 0.9rem;
}

/* QUIZ SECTION */
.quiz-section {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
    padding: 20px;
}

.question {
    font-size: 1.2rem;
    margin-bottom: 20px;
}

.quiz-buttons {
    display: flex;
    justify-content: center;
    gap: 15px;
}

.quiz-btn {
    background-color: #fff;
    border: 1px solid #2c2c2c;
    color: #2c2c2c;
    padding: 10px 30px;
    font-size: 1rem;
    cursor: pointer;
    border-radius: 25px;
    transition: all 0.3s ease;
}

.quiz-btn:hover {
    background-color: #2c2c2c;
    color: #fff;
}

#quiz-result {
    margin-top: 20px;
    font-weight: bold;
    color: #8b0000; /* Deep red for a pop of color */
}

.hidden {
    display: none;
}

/* CALL TO ACTION / WHATSAPP SECTION */
.cta-section {
    text-align: center;
    padding: 40px 20px;
    background-color: #fff;
    max-width: 600px;
    margin: 0 auto 40px;
    border-radius: 8px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
}

.whatsapp-btn {
    display: inline-block;
    background-color: #25D366; /* Official WhatsApp Green */
    color: #fff;
    text-decoration: none;
    padding: 12px 25px;
    border-radius: 25px;
    font-family: 'Arial', sans-serif;
    font-weight: bold;
    margin-top: 20px;
    transition: background-color 0.3s ease;
}

.whatsapp-btn:hover {
    background-color: #128C7E;
}

/* FOOTER */
footer {
    text-align: center;
    padding: 20px;
    background-color: #2c2c2c;
    color: #fff;
    font-size: 0.9rem;
}
